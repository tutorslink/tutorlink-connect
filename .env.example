# Tutors Link — Environment Configuration Template
# Copy to .env for local dev. Production/preview values are managed by Lovable Cloud.
# NEVER commit real secrets. Frontend values MUST be prefixed with VITE_.

# --- Public (safe for frontend bundle) ---
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# --- Server-only (never exposed to the client) ---
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""     # managed by Lovable Cloud; do not paste manually
SUPABASE_DB_URL=""                # managed by Lovable Cloud
LOVABLE_API_KEY=""                # AI Gateway; managed by Lovable Cloud

# --- Feature flags (optional) ---
# FEATURE_AI_ASSISTANT="true"
# FEATURE_DISCORD_SYNC="false"

# --- Future integrations (add via add_secret when introduced) ---
# OPENAI_API_KEY=""
# DISCORD_BOT_TOKEN=""
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
